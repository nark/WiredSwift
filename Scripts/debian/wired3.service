[Unit]
Description=Wired 3 server
After=network.target

[Service]
Type=simple
User=wired3
Group=wired3
WorkingDirectory=/var/lib/wired3
StateDirectory=wired3
StateDirectoryMode=0750
ExecStart=/usr/local/bin/wired3 --working-directory /var/lib/wired3
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
