#!/usr/bin/env bash
set -euo pipefail

if ! getent group wired3 >/dev/null 2>&1; then
  groupadd --system wired3
fi

if ! id -u wired3 >/dev/null 2>&1; then
  useradd \
    --system \
    --gid wired3 \
    --home-dir /var/lib/wired3 \
    --create-home \
    --shell /usr/sbin/nologin \
    --comment "Wired 3 service account" \
    wired3
fi

install -d -m 0750 -o wired3 -g wired3 /var/lib/wired3
install -d -m 0755 /etc/wired3

DEFAULT_SPEC_SOURCE="/usr/share/wired3/wired.xml"
DEFAULT_BANNER_SOURCE="/usr/share/wired3/banner.png"
DEFAULT_CONFIG_SOURCE="/usr/share/wired3/config.ini.example"

test -f "$DEFAULT_SPEC_SOURCE"
test -f "$DEFAULT_BANNER_SOURCE"
test -f "$DEFAULT_CONFIG_SOURCE"

if [[ ! -f /var/lib/wired3/wired.xml ]] || ! cmp -s "$DEFAULT_SPEC_SOURCE" /var/lib/wired3/wired.xml; then
  install -m 0640 -o wired3 -g wired3 "$DEFAULT_SPEC_SOURCE" /var/lib/wired3/wired.xml
fi

if [[ ! -f /var/lib/wired3/banner.png ]]; then
  install -m 0644 -o wired3 -g wired3 "$DEFAULT_BANNER_SOURCE" /var/lib/wired3/banner.png
fi

if [[ ! -f /etc/wired3/config.ini ]]; then
  install -m 0640 -o root -g wired3 "$DEFAULT_CONFIG_SOURCE" /etc/wired3/config.ini
fi

# SECURITY (TOFU): wired-identity.key is generated by the server on first start
# at /var/lib/wired3/wired-identity.key. Enforce 0600 in case a previous install
# left it with looser permissions (e.g. if written before this hardening).
if [[ -f /var/lib/wired3/wired-identity.key ]]; then
  chmod 0600 /var/lib/wired3/wired-identity.key
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
fi
