{
  "server": {
    "url": "wired://botuser:password@localhost:4871",
    "channels": [1],
    "reconnectDelay": 30,
    "maxReconnectAttempts": 0,
    "specPath": null
  },
  "identity": {
    "nick": "WiredBot",
    "status": "Powered by AI — say hi!",
    "icon": null,
    "idleTimeout": 0
  },
  "llm": {
    "provider": "ollama",
    "endpoint": "http://localhost:11434",
    "apiKey": null,
    "model": "llama3",
    "systemPrompt": "You are WiredBot, a helpful and friendly AI chatbot on a Wired server. Be concise and keep responses under 300 characters when possible. Avoid markdown formatting — plain text only.",
    "temperature": 0.7,
    "maxTokens": 512,
    "contextMessages": 10,
    "timeoutSeconds": 30
  },
  "behavior": {
    "respondToMentions": true,
    "respondToAll": false,
    "respondToPrivateMessages": true,
    "greetOnJoin": true,
    "greetMessage": "Welcome, {nick}!",
    "farewellOnLeave": false,
    "farewellMessage": "Goodbye, {nick}!",
    "announceNewThreads": true,
    "announceNewThreadMessage": "New board post: \"{subject}\" by {nick}",
    "announceFileUploads": false,
    "announceFileMessage": "{nick} uploaded: {filename}",
    "rateLimitSeconds": 2,
    "maxResponseLength": 500,
    "ignoreOwnMessages": true,
    "ignoredNicks": [],
    "mentionKeywords": ["!bot", "@bot"]
  },
  "triggers": [
    {
      "name": "ping",
      "pattern": "^!ping$",
      "eventTypes": ["chat", "private"],
      "response": "Pong!",
      "useLLM": false,
      "caseSensitive": false,
      "cooldownSeconds": 0
    },
    {
      "name": "help",
      "pattern": "^!help",
      "eventTypes": ["chat", "private"],
      "response": "Commands: !ping, !help, !ask <question>, !tldr <text> | Mention me for AI chat!",
      "useLLM": false,
      "caseSensitive": false,
      "cooldownSeconds": 5
    },
    {
      "name": "ask",
      "pattern": "^!ask (.+)",
      "eventTypes": ["chat", "private"],
      "useLLM": true,
      "llmPromptPrefix": null,
      "caseSensitive": false,
      "cooldownSeconds": 2
    },
    {
      "name": "tldr",
      "pattern": "^!tldr (.+)",
      "eventTypes": ["chat"],
      "useLLM": true,
      "llmPromptPrefix": "Summarize this in one sentence: ",
      "caseSensitive": false,
      "cooldownSeconds": 5
    },
    {
      "name": "joke",
      "pattern": "^!joke",
      "eventTypes": ["chat", "private"],
      "useLLM": true,
      "llmPromptPrefix": "Tell a short, clean, funny joke: ",
      "caseSensitive": false,
      "cooldownSeconds": 10
    }
  ],
  "daemon": {
    "foreground": false,
    "pidFile": "/tmp/wiredbot.pid",
    "logFile": "/tmp/wiredbot.log",
    "logLevel": "INFO"
  }
}
